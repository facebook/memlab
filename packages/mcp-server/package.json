  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/memlab.git",
    "directory": "packages/mcp-server"
  },
  "scripts": {
    "build-pkg": "tsc",
    "test-pkg": "echo 'no tests yet'",
    "publish-patch": "npm publish",
